&lt;/ul&gt;
&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#python%E8%AF%AD%E8%A8%80%E5%AE%9E%E7%8E%B0&#34;&gt;Python语言实现&lt;/a&gt;
&lt;ul&gt;
&lt;li&gt;&lt;a href=&#34;#%E7%94%9F%E6%88%90100000%E4%B8%AA%E9%9A%8F%E6%9C%BA%E6%95%B0%E5%88%B0%E6%95%B0%E7%BB%84&#34;&gt;生成100000个随机数到数组&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#%E5%86%92%E6%B3%A1%E6%8E%92%E5%BA%8F%E5%8A%9F%E8%83%BD&#34;&gt;冒泡排序功能&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#%E5%BF%AB%E9%80%9F%E6%8E%92%E5%BA%8F%E5%8A%9F%E8%83%BD&#34;&gt;快速排序功能&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#%E8%AE%B0%E5%BD%95%E6%89%A7%E8%A1%8C%E6%97%B6%E9%97%B4%E5%B9%B6%E8%BF%9B%E8%A1%8C%E6%AF%94%E8%BE%83&#34;&gt;记录执行时间并进行比较&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#%E4%B8%BB%E7%A8%8B%E5%BA%8F&#34;&gt;主程序&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#%E5%85%B3%E4%BA%8E%E6%9C%AC%E6%96%87%E6%A1%A3%E7%9A%84%E6%92%B0%E5%86%99&#34;&gt;关于本文档的撰写&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id=&#34;c语言实现&#34;&gt;C语言实现&lt;/h2&gt;
&lt;blockquote&gt;
&lt;p&gt;随机生成 100000个随机数，进行冒泡排序和快速排序，并比较执行时间。&lt;/p&gt;
&lt;/blockquote&gt;
&lt;h3 id=&#34;生成100000个随机数&#34;&gt;生成100000个随机数&lt;/h3&gt;
&lt;ul&gt;
&lt;li&gt;引用头文件&lt;/li&gt;
&lt;/ul&gt;
&lt;pre tabindex=&#34;0&#34;&gt;&lt;code&gt;#include &amp;lt;stdlib.h&amp;gt;  
// 使用其中的rand()函数
#include &amp;lt;time.h&amp;gt;   
// 记录执行时间 
// 使用其中的time()函数为随机数做种子，以保证“随机”
&lt;/code&gt;&lt;/pre&gt;&lt;ul&gt;
&lt;li&gt;使用time()为随机数做种&lt;/li&gt;
&lt;/ul&gt;
&lt;pre tabindex=&#34;0&#34;&gt;&lt;code&gt;srand(time(NULL));
&lt;/code&gt;&lt;/pre&gt;&lt;ul&gt;
&lt;li&gt;生成100000个随机数&lt;/li&gt;
&lt;/ul&gt;
&lt;pre tabindex=&#34;0&#34;&gt;&lt;code&gt;int a[100001] = {0};
for (int i = 0; i &amp;lt; 100000; i++) {
    a[i] = rand() % 1000000;
}
&lt;/code&gt;&lt;/pre&gt;&lt;h3 id=&#34;实现冒泡排序功能&#34;&gt;实现&lt;strong&gt;冒泡排序&lt;/strong&gt;功能&lt;/h3&gt;
&lt;pre tabindex=&#34;0&#34;&gt;&lt;code&gt;void bubble_sort(int a[], int n) {
    int i, j, temp;
    for (i = 0; i &amp;lt; n-1; i++) {
        for (j = 0; j &amp;lt; n-i-1; j++) {
            if (a[j] &amp;gt; a[j+1]) {
                temp = a[j];
                a[j] = a[j+1];
                a[j+1] = temp;
            }
        }
    }
}
&lt;/code&gt;&lt;/pre&gt;&lt;h3 id=&#34;实现快速排序功能&#34;&gt;实现&lt;strong&gt;快速排序&lt;/strong&gt;功能&lt;/h3&gt;
&lt;pre tabindex=&#34;0&#34;&gt;&lt;code&gt;void quick_sort(int a[], int low, int high) {
    if (low &amp;lt; high) {
        int pivot = a[high];
        int i = low - 1;
        for (int j = low; j &amp;lt; high; j++) {
            if (a[j] &amp;lt; pivot) {
                i++;
                int temp = a[i];
                a[i] = a[j];
                a[j] = temp;
            }
        }
        int temp = a[i + 1];
        a[i + 1] = a[high];
        a[high] = temp;
        int pi = i + 1;
        quick_sort(a, low, pi - 1);
        quick_sort(a, pi + 1, high);
    }
}
&lt;/code&gt;&lt;/pre&gt;&lt;h3 id=&#34;分别记录两者执行时间并进行比较&#34;&gt;分别记录两者&lt;strong&gt;执行时间&lt;/strong&gt;，并进行&lt;strong&gt;比较&lt;/strong&gt;&lt;/h3&gt;
&lt;ul&gt;
&lt;li&gt;使用两个变量分别记录开始与结束时间&lt;/li&gt;
&lt;/ul&gt;
&lt;pre tabindex=&#34;0&#34;&gt;&lt;code&gt;clock_t start, end;
&lt;/code&gt;&lt;/pre&gt;&lt;ul&gt;
&lt;li&gt;
&lt;p&gt;在排序功能执行的代码前后分别加上&lt;br&gt;
&lt;code&gt;start = clock();&lt;/code&gt;
&lt;code&gt;end = clock();&lt;/code&gt;&lt;br&gt;
记录对应的时间&lt;/p&gt;</description>
