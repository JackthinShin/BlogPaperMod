&lt;li&gt;&lt;a href=&#34;#%E7%94%9F%E6%88%90100000%E4%B8%AA%E9%9A%8F%E6%9C%BA%E6%95%B0&#34;&gt;生成100000个随机数&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#%E5%AE%9E%E7%8E%B0%E5%86%92%E6%B3%A1%E6%8E%92%E5%BA%8F%E5%8A%9F%E8%83%BD&#34;&gt;实现&lt;strong&gt;冒泡排序&lt;/strong&gt;功能&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#%E5%AE%9E%E7%8E%B0%E5%BF%AB%E9%80%9F%E6%8E%92%E5%BA%8F%E5%8A%9F%E8%83%BD&#34;&gt;实现&lt;strong&gt;快速排序&lt;/strong&gt;功能&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&#34;#%E5%88%86%E5%88%AB%E8%AE%B0%E5%BD%95%E4%B8%A4%E8%80%85%E6%89%A7%E8%A1%8C%E6%97%B6%E9%97%B4%E5%B9%B6%E8%BF%9B%E8%A1%8C%E6%AF%94%E8%BE%83&#34;&gt;分别记录两者&lt;strong&gt;执行时间&lt;/strong&gt;，并进行&lt;strong&gt;比较&lt;/strong&gt;&lt;/a&gt;&lt;/li&gt;
